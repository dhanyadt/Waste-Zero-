{
  "info": {
    "_postman_id": "waste-zero-api-collection",
    "name": "Waste Zero API",
    "description": "Complete API test collection for Waste Zero backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "VOLUNTEER_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "NGO_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "OPP_ID",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Volunteer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Volunteer\",\n  \"email\": \"volunteer@example.com\",\n  \"username\": \"johnvolunteer\",\n  \"password\": \"TestPass123!\",\n  \"role\": \"volunteer\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}", "/auth/register"]
            },
            "description": "Register a new volunteer user"
          },
          "response": []
        },
        {
          "name": "Register NGO",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Green Earth NGO\",\n  \"email\": \"ngo@example.com\",\n  \"username\": \"greenearth\",\n  \"password\": \"NgoPwd123!\",\n  \"role\": \"ngo\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}", "/auth/register"]
            },
            "description": "Register a new NGO user"
          },
          "response": []
        },
        {
          "name": "Login Volunteer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"volunteer@example.com\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}", "/auth/login"]
            },
            "description": "Login as volunteer - Save the token"
          },
          "response": []
        },
        {
          "name": "Login NGO",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ngo@example.com\",\n  \"password\": \"NgoPwd123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}", "/auth/login"]
            },
            "description": "Login as NGO - Save the token as {{NGO_TOKEN}}"
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{VOLUNTEER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}", "/auth/me"]
            },
            "description": "Get current user profile"
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{VOLUNTEER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Volunteer Updated\",\n  \"skills\": [\"Teaching\", \"Leadership\", \"Physical Labor\"],\n  \"location\": \"NYC\",\n  \"bio\": \"Passionate environmental volunteer\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}", "/auth/me"]
            },
            "description": "Update user profile"
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{VOLUNTEER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"TestPass123!\",\n  \"newPassword\": \"NewPass456@\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/change-password",
              "host": ["{{BASE_URL}}", "/auth/change-password"]
            },
            "description": "Change user password"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "Create Opportunity (NGO)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{NGO_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Community Cleanup Drive\",\n  \"description\": \"Join us in cleaning up the local park and making it a beautiful place\",\n  \"duration\": \"3 hours\",\n  \"location\": \"Central Park, NYC\",\n  \"requiredSkills\": [\"Physical Labor\", \"Leadership\"],\n  \"status\": \"open\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/opportunities",
              "host": ["{{BASE_URL}}", "/opportunities"]
            },
            "description": "Create a new opportunity (NGO only)"
          },
          "response": []
        },
        {
          "name": "Get All Opportunities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities",
              "host": ["{{BASE_URL}}", "/opportunities"]
            },
            "description": "Get all opportunities (public)"
          },
          "response": []
        },
        {
          "name": "Get Opportunities by Location",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities?location=NYC",
              "host": ["{{BASE_URL}}", "/opportunities"],
              "query": [
                {
                  "key": "location",
                  "value": "NYC"
                }
              ]
            },
            "description": "Filter opportunities by location"
          },
          "response": []
        },
        {
          "name": "Get Opportunities by Skills",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities?skills=Physical%20Labor,Leadership",
              "host": ["{{BASE_URL}}", "/opportunities"],
              "query": [
                {
                  "key": "skills",
                  "value": "Physical Labor,Leadership"
                }
              ]
            },
            "description": "Filter opportunities by required skills"
          },
          "response": []
        },
        {
          "name": "Get Opportunities by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities?status=open",
              "host": ["{{BASE_URL}}", "/opportunities"],
              "query": [
                {
                  "key": "status",
                  "value": "open"
                }
              ]
            },
            "description": "Filter opportunities by status"
          },
          "response": []
        },
        {
          "name": "Get Single Opportunity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities/{{OPP_ID}}",
              "host": ["{{BASE_URL}}", "/opportunities/{{OPP_ID}}"]
            },
            "description": "Get a single opportunity by ID"
          },
          "response": []
        },
        {
          "name": "Get My Opportunities (NGO)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{NGO_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/opportunities/my-opportunities",
              "host": ["{{BASE_URL}}", "/opportunities/my-opportunities"]
            },
            "description": "Get all opportunities created by the logged-in NGO"
          },
          "response": []
        },
        {
          "name": "Update Opportunity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{NGO_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Community Cleanup\",\n  \"description\": \"Join us in cleaning up - UPDATED!\",\n  \"status\": \"closed\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/opportunities/{{OPP_ID}}",
              "host": ["{{BASE_URL}}", "/opportunities/{{OPP_ID}}"]
            },
            "description": "Update an opportunity (owner NGO only)"
          },
          "response": []
        },
        {
          "name": "Delete Opportunity",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{NGO_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/opportunities/{{OPP_ID}}",
              "host": ["{{BASE_URL}}", "/opportunities/{{OPP_ID}}"]
            },
            "description": "Delete an opportunity (owner NGO only)"
          },
          "response": []
        }
      ]
    },
