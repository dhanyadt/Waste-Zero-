      ]
    },
    {
      "name": "Test Cases",
      "item": [
        {
          "name": "Volunteer Cannot Create Opportunity",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{VOLUNTEER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"This should fail\",\n  \"description\": \"Testing role authorization\",\n  \"duration\": \"2 hours\",\n  \"location\": \"NYC\",\n  \"status\": \"open\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/opportunities",
              "host": ["{{BASE_URL}}", "/opportunities"]
            },
            "description": "Should return 403 Forbidden"
          },
          "response": []
        },
        {
          "name": "Missing Authorization Header",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}", "/auth/me"]
            },
            "description": "Should return 401 Unauthorized"
          },
          "response": []
        },
        {
          "name": "Invalid Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid.token.here"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/me",
              "host": ["{{BASE_URL}}", "/auth/me"]
            },
            "description": "Should return 401 Unauthorized"
          },
          "response": []
        },
        {
          "name": "Invalid Status Filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/opportunities?status=invalid",
              "host": ["{{BASE_URL}}", "/opportunities"],
              "query": [
                {
                  "key": "status",
                  "value": "invalid"
                }
              ]
            },
            "description": "Should return 400 Bad Request"
          },
          "response": []
        }
      ]
    }
  ]
