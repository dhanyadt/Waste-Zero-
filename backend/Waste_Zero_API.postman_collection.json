              },
              {
                "key": "Authorization",
                "value": "Bearer {{VOLUNTEER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ngo\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/users/set-role",
              "host": ["{{BASE_URL}}", "/users/set-role"]
            },
            "description": "Set or update user role (used after Google OAuth)"
          },
          "response": []
